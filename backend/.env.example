# Copy this file to a new file named `.env` in this same folder (backend/).
# `.env` must be a FILE named exactly `.env` — do not create a folder called `.env`.
# Paste your key on the GEMINI_API_KEY line (no quotes needed).
# Get a key: https://aistudio.google.com/apikey
# Never commit `.env` — it stays on your machine only.

GEMINI_API_KEY=
# Optional — default is gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# --- Browser Use Cloud (optional): automated browser tasks from Live actions ---
# Create an API key: https://cloud.browser-use.com/settings → API keys
# Use ONE of the following (same key; two names so you can match other docs):
BROWSER_USE_API_KEY=
# BROWSER_USE_CLOUD_API_KEY=

# Optional — REST client uses https://api.browser-use.com/api/v2/tasks (see browserUseCloud.js)
# BROWSER_USE_LLM=browser-use-llm
# BROWSER_USE_FLASH_MODE=false

# PORT=3001

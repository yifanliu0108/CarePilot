# Copy this file to a new file named `.env` in this same folder (backend/).
# `.env` must be a FILE named exactly `.env` — do not create a folder called `.env`.
# Paste your key on the GEMINI_API_KEY line (no quotes needed — quotes are stripped).
# Get a key: https://aistudio.google.com/apikey
# Never commit `.env` — it stays on your machine only.
#
# Env load order: repo-root `.env` first, then `backend/.env`. If you leave
# `GEMINI_API_KEY=` empty below, the server keeps a non-empty key from the repo root
# (so copying this file does not wipe your root key).
# Verify: GET http://localhost:3001/api/health — geminiKey.keyLength ~39, looksLikeGoogleApiKey true.

GEMINI_API_KEY=
# Optional — default is gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# --- RAG (retrieval for Gemini assist): curated corpus + embeddings ---
# Uses the same GEMINI_API_KEY. First assist request indexes the corpus (small one-time latency).
# Embeddings use a separate quota/rate bucket from chat; if AI Studio “usage” looks fine but you
# still see 429, try RAG_DISABLED=1 or RAG_EMBEDDING_CACHE_DISABLED=1 (see embeddings-cache.json).
# GEMINI_EMBEDDING_MODEL=text-embedding-004
# RAG_TOP_K=4
# RAG_MIN_SCORE=0.1
# RAG_KEYWORD_WEIGHT=0.22
# RAG_EMBEDDING_CACHE_DISABLED=1
# RAG_DISABLED=1

# Optional — generateContent timeout (ms). 0 disables. Default 120000.
# GEMINI_REQUEST_TIMEOUT_MS=120000

# Optional — sampling (defaults: care 0.32, nutrition 0.35, topP 0.92). Lower temperature = steadier JSON + report layout.
# GEMINI_TEMPERATURE_CARE=0.32
# GEMINI_TEMPERATURE_NUTRITION=0.35
# GEMINI_TEMPERATURE=0.33
# GEMINI_TOP_P=0.92

# --- Browser Use Cloud (optional): automated browser tasks from Live actions ---
# Create an API key: https://cloud.browser-use.com/settings → API keys
# Use ONE of the following (same key; two names so you can match other docs):
BROWSER_USE_API_KEY=
# BROWSER_USE_CLOUD_API_KEY=

# Optional — Browser Use Cloud v2 tasks (see browserUseCloud.js)
# Default model is browser-use-llm (faster / lower cost per step). Override e.g.:
# BROWSER_USE_LLM=gemini-flash-lite-latest
# BROWSER_USE_LLM=browser-use-2.0
# BROWSER_USE_FLASH_MODE=false
# Fewer grocery stores & queries (Walmart + Vons only) for speed:
# BROWSER_USE_GROCERY_FAST=1
# Fewer care / Maps results:
# BROWSER_USE_CARE_FAST=1

# --- Google Maps Platform (optional): nearby grocery + care search in Chat sidebar ---
# Use this exact name (copy/paste): GOOGLE_MAPS_API_KEY
# Enable "Places API" and "Geocoding API" on your GCP project; restrict the key to those + your server IP if deployed.
# No quotes needed: GOOGLE_MAPS_API_KEY=AIza...
# GOOGLE_MAPS_API_KEY=

# PORT=3001

# --- Production (Docker / hosted): comma-separated browser origins for CORS, e.g. https://myapp.fly.dev
# CORS_ORIGINS=https://example.com

# Serve built SPA from frontend/dist (set SERVE_SPA=0 for API-only behind nginx)
# STATIC_DIST=
# SERVE_SPA=
